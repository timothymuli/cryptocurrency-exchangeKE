# Leave empty locally — Create React App proxies /api to Django on port 8000.
# If the React build talks to a hosted API, set the base URL (no slash at the end):
# REACT_APP_API_URL=https://your-api.example.com

# Django (only on the machine or host that runs the API)
# DJANGO_SECRET_KEY=change-me
# DJANGO_DEBUG=False
# ALLOWED_HOSTS=127.0.0.1,localhost,.onrender.com
# CORS_EXTRA_ORIGINS=https://yourusername.github.io,https://wherever-the-front-lives.com
